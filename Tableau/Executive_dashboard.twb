      <aliases enabled='yes' />
      <column caption='Cost' datatype='real' name='[Calculation_1263355537424385]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Oder Value' datatype='real' name='[Calculation_1263355537575938]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate ' datatype='real' name='[Calculation_1263355537797123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1263355539730436]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;Fast (0-2 Days)&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN &quot;Medium (3-5 Days)&quot;&#13;&#10;ELSE &quot;Delayed (6+ Days)&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_1263355541098501]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Profit Status' datatype='string' name='[Calculation_1263355541262342]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [profit] &gt; 0 THEN &quot;Profitable&quot;&#13;&#10;ELSE &quot;Loss&quot;&#13;&#10;END' />
      </column>
